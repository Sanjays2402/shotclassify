# Multi-stage production Dockerfile for the shotclassify RQ worker.

ARG PYTHON_VERSION=3.11
ARG APP_UID=10001
ARG APP_GID=10001

############################
# Stage 1: builder
############################
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_LINK_MODE=copy

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc g++ \
        libpq-dev libffi-dev libssl-dev \
        libjpeg-dev zlib1g-dev \
        libtesseract-dev libgl1 libglib2.0-0 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /build
COPY pyproject.toml ./
COPY packages ./packages
COPY services ./services
COPY cli ./cli

RUN uv pip install --system --no-cache \
        -e ./packages/common \
        -e ./packages/ocr \
        -e ./packages/classify \
        -e ./packages/extract \
        -e ./packages/route \
        -e ./packages/store \
        -e ./cli \
    && uv pip install --system --no-cache \
        "rq>=1.16" "redis>=5.0" \
        "pillow>=10.3" "pytesseract>=0.3.10" \
        "opencv-python-headless>=4.10" "numpy>=1.26" \
        "langdetect>=1.0.9" "openai>=1.40" "httpx>=0.27" \
        "pygments>=2.18" "pyyaml>=6.0" "structlog>=24.1" \
        "sqlalchemy>=2.0" "psycopg2-binary>=2.9" \
        "pydantic>=2.7" "pydantic-settings>=2.4" \
        "authlib>=1.3" "itsdangerous>=2.2" \
        "sentry-sdk>=2.0"

############################
# Stage 2: runtime
############################
FROM python:${PYTHON_VERSION}-slim AS runtime

ARG APP_UID
ARG APP_GID

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr libgl1 libglib2.0-0 libpq5 tini ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid ${APP_GID} app \
    && useradd  --system --uid ${APP_UID} --gid ${APP_GID} \
        --home-dir /app --shell /usr/sbin/nologin app

COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app
COPY --chown=app:app packages ./packages
COPY --chown=app:app services ./services
COPY --chown=app:app cli ./cli
COPY --chown=app:app pyproject.toml ./pyproject.toml

RUN mkdir -p /app/storage && chown -R app:app /app/storage

USER app:app

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python", "-m", "services.worker.app.main"]
