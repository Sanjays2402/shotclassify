# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=7441
APP_SECRET_KEY=change-me-please-32-bytes-min-xxx
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-west-2

# Database
DATABASE_URL=sqlite:///./shotclassify.db

# Redis / queue
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=shotclassify

# Vision LLM (OpenAI-compatible)
LLM_BASE_URL=http://127.0.0.1:4141/v1
LLM_API_KEY=copilot
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=2

# OCR
OCR_LANG=eng
OCR_PSM=6
OCR_DESKEW=true

# Auth
AUTH_ENABLED=true
AUTH_OAUTH_PROVIDER=github
AUTH_OAUTH_CLIENT_ID=
AUTH_OAUTH_CLIENT_SECRET=
AUTH_ALLOWED_GITHUB_LOGIN=Sanjays2402
AUTH_API_KEY=set-a-strong-token-here
# Extra API keys with roles (JSON object: {key: role}). Roles: admin, operator, viewer.
# AUTH_API_KEY above is always treated as admin.
AUTH_API_KEYS=
# Per-login role assignments for OAuth users (JSON object: {login: role}).
AUTH_ROLE_MAP=
# Fallback role for authenticated principals not matched above.
AUTH_DEFAULT_ROLE=viewer

# Multi-tenancy: JSON object mapping API keys or OAuth logins to tenant ids.
# Anyone not matched falls through to AUTH_DEFAULT_TENANT. Admins may pass
# X-Tenant: * to opt into a cross-tenant view or X-Tenant: <id> to operate
# inside a specific tenant.
AUTH_TENANT_MAP=
AUTH_DEFAULT_TENANT=default

# Routing
ROUTE_RULES_PATH=./packages/route/rules.example.yaml
ROUTE_DRY_RUN=true
ROUTE_SLACK_WEBHOOK=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_IP_RPM=120
RATE_LIMIT_PER_KEY_RPM=600
RATE_LIMIT_BURST=20
RATE_LIMIT_EXEMPT_PATHS=/healthz,/readyz,/metrics,/blob

# Telemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=shotclassify-api

# Error tracking (Sentry). Leave SENTRY_DSN empty to disable.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# CORS allowlist. In production set CORS_ALLOWED_ORIGINS to an explicit
# comma-separated list (e.g. https://app.example.com,https://admin.example.com).
# A wildcard ``*`` is only honored when APP_ENV=development.
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-Request-ID,X-Tenant

# Security response headers (CSP, HSTS, Referrer-Policy, Permissions-Policy).
# HSTS is only emitted when APP_ENV=production.
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# CI
ENABLE_CI=false
