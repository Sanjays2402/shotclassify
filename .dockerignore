# Keep build context small and avoid leaking secrets/state into images.
.git
.github
.venv
.pytest_cache
.ruff_cache
__pycache__
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info
node_modules
web/node_modules
web/.next
web/out
.env
.env.*
!.env.example
storage/
samples/
fixtures/
*.db
*.sqlite*
docs/
README.md
LICENSE
Makefile
infra/terraform
infra/helm
infra/docker/docker-compose*.yml
